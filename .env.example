# Blogger API credentials
BLOG_ID=your_blogger_blog_id
CLIENT_ID=your_google_oauth_client_id
CLIENT_SECRET=your_google_oauth_client_secret
REFRESH_TOKEN=your_google_oauth_refresh_token

# Agnes AI credentials
AGNES_API_KEY=your_agnes_ai_api_key
# Optional: model name (defaults to agnes-2.0-flash)
# AGNES_MODEL=agnes-2.0-flash

# Optional: number of articles per run (defaults to 5)
# ARTICLES_PER_RUN=5
