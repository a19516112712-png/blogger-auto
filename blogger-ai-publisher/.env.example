# Database path (optional — defaults to database/blogger_ai_publisher.db)
# DATABASE_URL=sqlite:////custom/path/database.db

# =============================================================================
# Blogger AI Publisher Pro — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
#   cp .env.example .env
# =============================================================================

# ---------------------------------------------------------------------------
# Blogger API (REQUIRED for publishing)
# ---------------------------------------------------------------------------
BLOG_ID=122799461405250161
CLIENT_ID=
CLIENT_SECRET=
REFRESH_TOKEN=
BLOG_URL=https://babynameideas2026.blogspot.com

# ---------------------------------------------------------------------------
# AI Generation (REQUIRED for article generation)
# ---------------------------------------------------------------------------
AGNES_API_KEY=
AGNES_MODEL=agnes-2.0-flash
AGNES_BASE_URL=https://apihub.agnes-ai.com/v1

# ---------------------------------------------------------------------------
# Image Engine
# ---------------------------------------------------------------------------
IMAGE_OUTPUT_WIDTH=1600
IMAGE_OUTPUT_HEIGHT=900
IMAGE_OUTPUT_FORMAT=WEBP
IMAGE_OUTPUT_QUALITY=90
IMAGE_MAX_FILE_SIZE=307200
IMAGE_PROVIDERS=huggingface,pollinations
IMAGE_MAX_RETRIES=5
IMAGE_PHASH_THRESHOLD=5

# HuggingFace Inference API (required if huggingface is in IMAGE_PROVIDERS)
HUGGINGFACE_API_TOKEN=
HUGGINGFACE_MODEL=black-forest-labs/FLUX.1-schnell

# Pollinations API (optional override)
# POLLINATIONS_BASE_URL=https://image.pollinations.ai/prompt

# ---------------------------------------------------------------------------
# Publisher Engine
# ---------------------------------------------------------------------------
PUBLISHER_MAX_RETRIES=3
PUBLISHER_RETRY_DELAY_SECONDS=5
PUBLISHER_MAX_BACKOFF_SECONDS=60
PUBLISHER_IMAGE_MAX_RETRIES=3
PUBLISHER_SLUG_MAX_LENGTH=75
PUBLISHER_DEFAULT_LABELS=Baby Names

# ---------------------------------------------------------------------------
# Automation Engine
# ---------------------------------------------------------------------------
AUTOMATION_MAX_ARTICLES_PER_RUN=1
AUTOMATION_RETRY_FAILED=true
AUTOMATION_HEALTH_CHECK_ENABLED=true
AUTOMATION_MIN_DISK_SPACE_MB=500

# ---------------------------------------------------------------------------
# Content defaults
# ---------------------------------------------------------------------------
ARTICLES_PER_RUN=10
MIN_ARTICLE_WORDS=1500
TARGET_ARTICLE_WORDS=2500

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
LOG_LEVEL=INFO
# LOG_FORMAT=%(asctime)s [%(levelname)s] %(name)s: %(message)s
# LOG_DATE_FORMAT=%Y-%m-%d %H:%M:%S
